with Seq(type #h|#l, d)
def main() = new Seq(type 0..3, d) {
  repeat {
    on val(v) {
      val(#h)
      repeat d v { val(#h) }
      val(#l)
    }
    repeat { val(#l) }
  }
}

@test(#up, (#h, #l, #h, #h, #l, #h, #h, #h, #l))
with Seq(type #h|#l, _) def test1() = main() | seq { val(0); val(1); val(2) }
