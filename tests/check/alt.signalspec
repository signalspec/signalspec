with Seq(type #a|#b, _)
def bare() = seq {
    alt #up _ {
        #a => {
            val(#a)
        }
        #b => {
            val(#b)
        }
    }
}

@test(#up, (#a))
with Seq(type #a|#b, _) def test1() = seq {
    bare()
}

with Seq(type #a|#b, _)
def constant() = seq {
    alt #const #b {
        #a => {
            val(#a)
        }
        #b => {
            val(#b)
        }
        #c => {
            val(#c)
        }
    }
}

@test(#both, (#b))
with Seq(type #a|#b, _) def test_constant() = seq {
    constant()
}

with Seq(type #a|#b, _)
def constant_destructure() = seq {
    alt #const (#a, [#b, #c, #d, #e]) {
        (#a, [x, 2:[#c, #d], #e]) => {
            val(x)
        }
    }
}

@test(#both, (#b))
with Seq(type #a|#b, _) def test_constant_destructure() = seq {
    constant_destructure()
}

with Seq(type #a|#b, dir)
def simple() = new Seq(type #a|#b, dir) {
    on val(x) {
        alt dir x {
            #a => {
                val(#a)
                val(#b)
            }
            #b => {
                val(#b)
                val(#a)
            }
        }
    }
}

@test(#both, (#b, #a))
with Seq(type #a|#b, _) def test2() = seq {
    simple() | seq { val(#b) }
}

@test(#both, (#a, #b))
with Seq(type #a|#b, _) def test2() = seq {
    simple() | seq { val(#a) }
}

with Seq(type #a|#b, dir)
def ambiguous() = new Seq(type #a|#b, dir) {
    on val(x) {
        alt dir x {
            #b => {
                val(#a)
                val(#b)
                val(#a)
            }
            #a => {
                val(#a)
                val(#a)
                val(#b)
            }
        }
    }
}

with Seq(type (#ones|#bit|#two, bits(2)), dir)
def vector_map() = new Seq(bits(4), dir) {
    repeat {
        on val(x) {
            alt dir x {
                '1111 => { val((#ones, '00)) }
                [1, 1, 0, x] => { val((#bit, [0, x])) }
                [2:'00, 2:x] => { val((#two, x)) }
            }
        }
    }
}

@test(#both, ((#ones, '00), (#bit, '01), (#two, '10)))
with Seq(type (#ones|#bit|#two, bits(2)), dir) def vector() = vector_map() | seq { val('1111); val('1101); val('0010) }


//test
