let T = type #a|#b|#c|#d

with Seq(type T, dir)
def main(x) = seq {
    val(#a)
    val(#b)
    repeat dir x {
        val(#c)
        val(#d)
    }
    val(#a)
}

@test(#both, (#a, #b, #a))
with Seq(type T, _) def test1() = main(0)

@test(#up_fail, (#a, #b, #a))
@test(#both, (#a, #b, #c, #d, #a))
with Seq(type T, _) def test2() = main(1)

@test(#dn, (#a, #b, #c, #d, #c, #d, #a))
with Seq(type T, _) def test3() = main(2)

@test(#up_fail, (#a, #b, #c, #a))
@test(#up_fail, (#a, #b, #c, #d))
@test(#up, (#a, #b, #c, #d, #a))
@test(#up, (#a, #b, #c, #d, #c, #d, #a))
@test(#up, (#a, #b, #c, #d, #c, #d, #c, #d, #a))
with Seq(type T, _) def test4() = main(_)
