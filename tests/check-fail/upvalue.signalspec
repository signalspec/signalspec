@test(#up, (9))
with Seq(type 1..10, _) def main() = new Seq(type 1..10, #up) {
//# value for up-direction variable provided multiple times
    on val(v) {
//         ^ must be up-evaluated exactly once in this block
        val(v)
//          ^ up-evaluated here
        val(v)
//          ^ up-evaluated here
    }

//# no value for up-direction variable provided
    on val(v) {
//         ^ must be up-evaluated exactly once in this block

    }
}

@test(#up, (9))
with Seq(type 1..10, _) def main() = new Seq(type [1..10; 2], #up) {
    on val(xy) {
//# value for up-direction variable provided multiple times
        for ab = xy {
//          ^^ must be up-evaluated exactly once in this block
            val(ab)
//              ^^ up-evaluated here
            val(ab)
//              ^^ up-evaluated here
        }
    }
}

@test(#up, (9))
with Seq(type 1..10, _) def main() = seq {
//# no value for up-direction variable provided
    alt #up _ {
        a => {
//      ^ must be up-evaluated exactly once in this block

        }
    }
}
