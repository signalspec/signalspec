@test(#up, ())
with Seq(type #x, _) def main() = seq {
//# expected a single value
    repeat #up (1, 2) {
//             ^^^^^^ found `(1, 2)`

    }
}

@test(#up, ())
with Seq(type #x, _) def main() = seq {
//# repeat count must be a non-negative integer
    repeat #up (-1) {
//             ^^^^ found `-1`

    }

//# repeat count must be a non-negative integer
    repeat #up #a {
//             ^^ found `#a`

    }

//# repeat count must be a non-negative integer
    repeat #up (1|4|5) {
//             ^^^^^^^ found `<1 | 4 | 5>`

    }

//# repeat count must be a non-negative integer
    repeat #dn #a {
//             ^^ found `#a`

    }

//# expression cannot be evaluated as a value
    repeat #dn 1..10 {
//             ^^^^^ not compatible with down-evaluation

    }
}
